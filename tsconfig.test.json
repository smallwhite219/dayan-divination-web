{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-test",
    "rootDir": "."
  },
  "include": ["src/lib/**/*.ts", "scripts/**/*.ts"]
}
